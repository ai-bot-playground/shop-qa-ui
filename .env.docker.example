# .env.docker.example — szablon konfiguracji runtime dla kontenera.
# Skopiuj do .env.docker i uzupełnij klucze. .env.docker NIE trafia do obrazu ani gita
# (.gitignore / .dockerignore) — jest wstrzykiwany przez compose jako zmienne środowiskowe.
#
# Nazwy zmiennych zgodne z kodem aplikacji (src/agent.py, app.py) z brancha
# lk-prototype-adjustment. Endpoint zweryfikowany: ai-remik.services.ai.azure.com

# ─────────────────────────────────────────────────────────────
# Provider: azure | anthropic   (kod domyślnie: anthropic)
# ─────────────────────────────────────────────────────────────
LLM_PROVIDER=azure

# ─────────────────────────────────────────────────────────────
# KLUCZ API — zmienne czytane bezpośrednio przez src/agent.py
# (_api_key() / _ENDPOINT). To są placeholdery do podłączenia modelu.
# PUSTY KLUCZ = TRYB DEMONSTRACYJNY: aplikacja zwraca mockowane odpowiedzi LLM,
# aby można było przeklikać cały workflow bez podłączonego modelu.
# ─────────────────────────────────────────────────────────────
AZURE_ANTHROPIC_API_KEY=
AZURE_ANTHROPIC_ENDPOINT=https://ai-remik.services.ai.azure.com/anthropic/v1/messages

# ─────────────────────────────────────────────────────────────
# AZURE — model MOCNY (AKTYWNY): Claude Opus 4.8 → analiza / Q&A
# src/agent.py:_llm_azure woła {AZURE_AI_ENDPOINT}/v1/messages, auth: Bearer.
# ─────────────────────────────────────────────────────────────
AZURE_AI_ENDPOINT=https://ai-remik.services.ai.azure.com/anthropic
AZURE_AI_API_KEY=
AZURE_AI_DEPLOYMENT=claude-opus-4-8

# AZURE — model MAŁY (PLACEHOLDER w configu, kod jeszcze NIE używa): GPT-5.4-mini
# Docelowo proste zadania (docs, module overview, proposals).
AZURE_AI_DEPLOYMENT_FAST=gpt-5.4-mini
# Przyszły hook GPT (Azure OpenAI Responses API): {host}/openai/v1/responses, auth: Bearer
# AZURE_OPENAI_ENDPOINT=https://ai-remik.services.ai.azure.com/openai
# AZURE_OPENAI_API_KEY=

# ─────────────────────────────────────────────────────────────
# Alternatywa: provider anthropic (bezpośrednio Anthropic API)
# ─────────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=
# LLM_MODEL=claude-opus-4-8                  # model "slow" (Q&A)
# LLM_MODEL_FAST=claude-haiku-4-5-20251001   # model "fast" (docs/proposals)

# ─────────────────────────────────────────────────────────────
# Repo docelowe do indeksowania.
# Docelowo: legacy-satchmo (gdy dojdzie zapis wyników analizy). Na razie: sample.
# ─────────────────────────────────────────────────────────────
REPO_PATH=sample

# ─────────────────────────────────────────────────────────────
# GitHub — token używany przez krok "Piaskownica" (commit + push gałęzi
# ai-sandbox/<ts>, co uruchamia pipeline .github/workflows/sandbox-pr.yml).
# Pobierz token z zalogowanego gh:   gh auth token
# Wymaga uprawnień repo (push) + pull_requests. Wewnątrz kontenera bez tego
# tokena push się nie powiedzie (GUI pokaże komendę do ręcznego push).
# ─────────────────────────────────────────────────────────────
GH_TOKEN=

# ─────────────────────────────────────────────────────────────
# Streamlit
# ─────────────────────────────────────────────────────────────
STREAMLIT_PORT=8501
# APP_ENTRYPOINT=app.py
