# .env.docker.example — szablon konfiguracji runtime dla kontenera.
# Skopiuj do .env.docker i uzupełnij klucze. .env.docker NIE trafia do obrazu ani gita
# (.gitignore / .dockerignore) — jest wstrzykiwany przez compose jako zmienne środowiskowe.
#
# Nazwy zmiennych zgodne z kodem aplikacji (src/agent.py).

# ─────────────────────────────────────────────────────────────
# PRIMARY: OpenRouter (OpenAI-compatible, preferencyjny)
# PUSTY KLUCZ = TRYB DEMONSTRACYJNY: pełny workflow bez podłączonego modelu.
# ─────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_MODEL=z-ai/glm-5.2
OPENROUTER_REASONING_EFFORT=high
OPENROUTER_MAX_TOKENS=32000

# ─────────────────────────────────────────────────────────────
# ─────────────────────────────────────────────────────────────
# Diagnostyka (scripts/check_endpoints.py) — Azure AI Foundry Anthropic.
# Nie jest używana przez główny kod (OpenRouter jest aktywną ścieżką).
# ─────────────────────────────────────────────────────────────
AZURE_AI_ENDPOINT=https://ai-remik.services.ai.azure.com/anthropic
AZURE_AI_API_KEY=
AZURE_AI_DEPLOYMENT=claude-opus-4-8
AZURE_AI_DEPLOYMENT_FAST=gpt-5.4-mini

# ─────────────────────────────────────────────────────────────
# Repo docelowe do indeksowania (serwis z manifest.yaml albo katalog sample/).
# ─────────────────────────────────────────────────────────────
REPO_PATH=sample

# ─────────────────────────────────────────────────────────────
# GitHub — token używany przez krok "Piaskownica" (commit + push gałęzi
# ai-sandbox/<ts>, co uruchamia pipeline .github/workflows/sandbox-pr.yml).
# Pobierz token z zalogowanego gh:   gh auth token
# Wymaga uprawnień repo (push) + pull_requests.
# ─────────────────────────────────────────────────────────────
GH_TOKEN=

# ─────────────────────────────────────────────────────────────
# Streamlit
# ─────────────────────────────────────────────────────────────
STREAMLIT_PORT=8501
# APP_ENTRYPOINT=app.py
