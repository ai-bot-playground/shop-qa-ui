# Szablon konfiguracji lokalnej. Skopiuj do `.env` i uzupełnij klucz API.
#
#   cp .env.example .env
#
# WAŻNE: pusty klucz API = TRYB DEMONSTRACYJNY — aplikacja zwraca mockowane
# odpowiedzi LLM, aby można było przeklikać cały workflow bez podłączonego
# modelu. Po wpisaniu klucza kod automatycznie wraca do realnych wywołań.

# ─────────────────────────────────────────────────────────────
# PRIMARY: OpenRouter (OpenAI-compatible, preferencyjny)
# ─────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_MODEL=z-ai/glm-5.2
OPENROUTER_REASONING_EFFORT=high
OPENROUTER_MAX_TOKENS=32000

# ─────────────────────────────────────────────────────────────
# ─────────────────────────────────────────────────────────────
# Repo docelowe do indeksowania (domyślnie: katalog sample/).
# ─────────────────────────────────────────────────────────────
REPO_PATH=sample
